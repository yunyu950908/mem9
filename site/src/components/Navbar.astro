---
import type {
  SiteAriaCopy,
  SiteDictionary,
  SiteNavCopy,
  SiteThemeOptionsCopy,
} from '../content/site';

interface Props {
  nav: SiteNavCopy;
  aria: SiteAriaCopy;
  localeNames: SiteDictionary['localeNames'];
  themeOptions: SiteThemeOptionsCopy;
}

const { nav, aria, localeNames, themeOptions } = Astro.props;
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label={aria.home} data-i18n-attr="aria-label:aria.home">
      <span class="brand-text">MEM</span>
      <span class="brand-accent">9</span>
    </a>

    <div class="nav-right">
      <div class="nav-links">
        <a href="#top" data-i18n="nav.home">{nav.home}</a>
        <a href="#features" data-i18n="nav.features">{nav.features}</a>
        <a href="#platforms" data-i18n="nav.platforms">{nav.platforms}</a>
      </div>

      <div class="nav-actions">
        <div class="menu-shell" data-menu-shell="language" data-open="false">
          <button
            type="button"
            class="icon-button"
            data-menu-trigger="language"
            data-language-toggle
            aria-haspopup="menu"
            aria-expanded="false"
            aria-controls="language-menu"
            aria-label={aria.changeLanguage}
            title={aria.changeLanguage}
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M12 3a9 9 0 1 0 0 18a9 9 0 0 0 0-18Z"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.7"
              />
              <path
                d="M3.6 9.2h16.8M3.6 14.8h16.8M12 3c2.4 2.2 3.8 5.5 3.8 9s-1.4 6.8-3.8 9M12 3C9.6 5.2 8.2 8.5 8.2 12s1.4 6.8 3.8 9"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
              />
            </svg>
          </button>

          <div
            id="language-menu"
            class="nav-menu language-menu surface-card"
            data-menu="language"
            data-language-menu
            role="menu"
            hidden
          >
            <button
              type="button"
              class="menu-option is-active"
              data-set-locale="en"
              aria-pressed="true"
            >
              {localeNames.en}
            </button>
            <button
              type="button"
              class="menu-option"
              data-set-locale="zh"
              aria-pressed="false"
            >
              {localeNames.zh}
            </button>
            <button
              type="button"
              class="menu-option"
              data-set-locale="zh-Hant"
              aria-pressed="false"
            >
              {localeNames['zh-Hant']}
            </button>
            <button
              type="button"
              class="menu-option"
              data-set-locale="ja"
              aria-pressed="false"
            >
              {localeNames.ja}
            </button>
            <button
              type="button"
              class="menu-option"
              data-set-locale="ko"
              aria-pressed="false"
            >
              {localeNames.ko}
            </button>
            <button
              type="button"
              class="menu-option"
              data-set-locale="id"
              aria-pressed="false"
            >
              {localeNames.id}
            </button>
            <button
              type="button"
              class="menu-option"
              data-set-locale="th"
              aria-pressed="false"
            >
              {localeNames.th}
            </button>
          </div>
        </div>

        <div class="menu-shell" data-menu-shell="theme" data-open="false">
          <button
            type="button"
            class="icon-button"
            data-menu-trigger="theme"
            data-theme-toggle
            aria-haspopup="menu"
            aria-expanded="false"
            aria-controls="theme-menu"
            aria-label={aria.themeModeSystem}
            title={aria.themeModeSystem}
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M12 3.2v2.1M12 18.7v2.1M20.8 12h-2.1M5.3 12H3.2M18.2 5.8l-1.5 1.5M7.3 16.7l-1.5 1.5M18.2 18.2l-1.5-1.5M7.3 7.3L5.8 5.8"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.65"
              />
              <circle
                cx="12"
                cy="12"
                r="4"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.65"
              />
            </svg>
          </button>

          <div
            id="theme-menu"
            class="nav-menu theme-menu surface-card"
            data-menu="theme"
            data-theme-menu
            role="menu"
            hidden
          >
            <button
              type="button"
              class="menu-option"
              data-set-theme="light"
              data-i18n="themeOptions.light"
              aria-pressed="false"
            >
              {themeOptions.light}
            </button>
            <button
              type="button"
              class="menu-option"
              data-set-theme="dark"
              data-i18n="themeOptions.dark"
              aria-pressed="false"
            >
              {themeOptions.dark}
            </button>
            <button
              type="button"
              class="menu-option is-active"
              data-set-theme="system"
              data-i18n="themeOptions.system"
              aria-pressed="true"
            >
              {themeOptions.system}
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(14px);
    background: var(--nav-bg);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    min-height: 70px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.08em;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text);
  }

  .brand-accent {
    color: var(--accent);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    font-size: 0.95rem;
    color: var(--text-dim);
  }

  .nav-links a {
    color: inherit;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .menu-shell {
    position: relative;
  }

  .icon-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.55rem;
    height: 2.55rem;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--control-bg);
    color: var(--text);
    box-shadow: var(--surface-inset), var(--surface-shadow-soft);
    cursor: pointer;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .menu-shell[data-open='true'] .icon-button,
  .icon-button:hover {
    transform: translateY(-1px);
    background: var(--control-hover-bg);
    border-color: var(--button-active-border);
  }

  .icon-button svg {
    width: 1.15rem;
    height: 1.15rem;
  }

  .nav-menu {
    position: absolute;
    top: calc(100% + 0.7rem);
    right: 0;
    z-index: 30;
    padding: 0.45rem;
    display: grid;
    gap: 0.2rem;
    background: var(--menu-surface);
    border: 1px solid var(--border-strong);
    box-shadow: var(--menu-shadow);
  }

  .nav-menu[hidden] {
    display: none;
  }

  .language-menu {
    min-width: 11.5rem;
  }

  .theme-menu {
    min-width: 10.5rem;
  }

  .menu-option {
    border: 1px solid transparent;
    border-radius: 0.8rem;
    padding: 0.55rem 0.75rem;
    text-align: left;
    white-space: nowrap;
    color: var(--text-dim);
    background: transparent;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .menu-option:hover,
  .menu-option.is-active {
    background: var(--button-active-bg);
    border-color: var(--button-active-border);
    color: var(--text);
  }

  @media (max-width: 780px) {
    .nav-inner {
      min-height: 62px;
    }

    .nav-links {
      gap: 0.9rem;
      font-size: 0.87rem;
    }
  }

  @media (max-width: 560px) {
    .nav-right {
      gap: 0.7rem;
    }

    .nav-links a {
      display: none;
    }

    .language-menu {
      min-width: min(18rem, calc(100vw - 2rem));
      max-height: min(50vh, 16rem);
      grid-template-columns: repeat(2, minmax(0, 1fr));
      overflow-y: auto;
    }

    .language-menu .menu-option {
      min-height: 3rem;
      white-space: normal;
    }
  }
</style>
